# Public HTTPS URL of this server, no trailing slash (e.g. https://thinvite.example.com)
# Used for OAuth redirect URIs, EventSub webhook callback, CSP headers, and meta tags.
# This site must have a valid SSL certificate.
SITE_URL=

# Database
THINVITE_DB_PASSWORD=

# Twitch application credentials (https://dev.twitch.tv/console)
THINVITE_TWITCH_ID=
THINVITE_TWITCH_SECRET=

# Discord application credentials (https://discord.com/developers/applications)
THINVITE_DISCORD_ID=
THINVITE_DISCORD_SECRET=
THINVITE_DISCORD_BOT_TOKEN=

# Brevo (contact form + waitlist notifications) — https://app.brevo.com
BREVO_API_KEY=

# Verified sender address for transactional emails
SENDER_ADDRESS=

# Owner contact info (receives contact form submissions and waitlist notifications)
OWNER_EMAIL=
OWNER_NAME=

# Cloudflare Turnstile (https://dash.cloudflare.com — Turnstile)
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# NiceGUI signed-cookie secret - generate with: python -c "import secrets; print(secrets.token_hex(32))"
NICEGUI_STORAGE_SECRET=

# EventSub webhook secret — must be a strong random secret, min 10 chars
# generate with: python -c "import secrets; print(secrets.token_hex(32))"
THINVITE_EVENTSUB_SECRET=

# Twitch Extension (optional — only needed if using the panel extension)
# Found at https://dev.twitch.tv/console under your extension's settings
TWITCH_EXT_SECRET=
TWITCH_EXT_CLIENT_ID=
TWITCH_EXT_OWNER_ID=
